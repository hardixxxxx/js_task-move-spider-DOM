"use strict";
document.addEventListener("click", function(e) {
    var spider = document.querySelector(".spider");
    var wall = document.querySelector(".wall");
    var posY = e.y - wall.offsetTop - wall.clientTop - spider.clientHeight / 2;
    posY = Math.max(0, Math.min(posY, wall.clientHeight - spider.clientHeight));
    var posX = e.x - wall.offsetLeft - wall.clientLeft - spider.clientWidth / 2;
    posX = Math.max(0, Math.min(posX, wall.clientWidth - spider.clientWidth));
    spider.style.top = "".concat(posY, "px");
    spider.style.left = "".concat(posX, "px");
});

